# Prometheus API endpoint
PROMETHEUS_URL=http://prometheus:9090

# Grafana API endpoint and auth token
GRAFANA_URL=http://grafana:3000
GRAFANA_API_TOKEN=admin

# Allow browser access from all origins during development
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:5173
CORS_METHODS=GET,POST,OPTIONS

# Server configuration
PORT=3000
NODE_ENV=development

# Frontend runtime endpoints (Vite) - for development
VITE_API_BASE_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
VITE_COPILOT_PUBLIC_API_KEY=
