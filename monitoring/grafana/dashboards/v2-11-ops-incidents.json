{
  "annotations": {"list": []},
  "editable": true,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "grafana"},
      "description": "Failure-rate indicator for rapid incident triage.",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "targets": [{"expr": "mohawk:gradient_submit:failure_rate_5m", "refId": "A"}],
      "title": "Current Failure Ratio",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "grafana"},
      "description": "Absolute failure throughput.",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "targets": [{"expr": "sum(rate(mohawk_accelerator_ops_total{operation=\"gradient_submit\",result=\"failure\"}[5m]))", "refId": "A"}],
      "title": "Gradient Submit Failures (ops/s)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "grafana"},
      "description": "Successful throughput for comparison.",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "targets": [{"expr": "sum(rate(mohawk_accelerator_ops_total{operation=\"gradient_submit\",result=\"success\"}[5m]))", "refId": "A"}],
      "title": "Gradient Submit Success (ops/s)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "grafana"},
      "description": "Incident timeline: failures vs successes.",
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 6},
      "id": 4,
      "targets": [
        {"expr": "sum(rate(mohawk_accelerator_ops_total{operation=\"gradient_submit\",result=\"failure\"}[5m]))", "legendFormat": "submit failures", "refId": "A"},
        {"expr": "sum(rate(mohawk_accelerator_ops_total{operation=\"gradient_submit\",result=\"success\"}[5m]))", "legendFormat": "submit success", "refId": "B"}
      ],
      "title": "Gradient Incident Timeline",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "grafana"},
      "description": "Proof pipeline reliability trend.",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 6},
      "id": 5,
      "targets": [
        {"expr": "sum(rate(mohawk_proof_verifications_total{result=\"failure\"}[5m]))", "legendFormat": "proof failures", "refId": "A"},
        {"expr": "sum(rate(mohawk_proof_verifications_total{result=\"success\"}[5m]))", "legendFormat": "proof success", "refId": "B"}
      ],
      "title": "Proof Verification Incident Timeline",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "grafana"},
      "description": "Availability by monitored instance for triage.",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 16},
      "id": 6,
      "targets": [{"expr": "up{job=~\"orchestrator|tpm-metrics|node-agents|pyapi-exporter\"}", "legendFormat": "{{job}} {{instance}}", "refId": "A"}],
      "title": "Instance Availability",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["mohawk", "v2", "operations", "incidents"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "title": "MOHAWK v2 - Operations Incidents",
  "version": 1
}
