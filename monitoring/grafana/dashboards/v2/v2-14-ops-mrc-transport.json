{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "description": "MRC transport path dashboard backed by current gradient-submit, accelerator, and proof telemetry.",
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "MRC Transport Snapshot",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Gradient Throughput (1m)",
      "description": "Gradient submission rate used as the transport-path throughput signal.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "mohawk:gradient_submit:rate1m"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Gradient Success Ratio (5m)",
      "description": "Transport success proxy derived from gradient submit failures over the last 5 minutes.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1 - mohawk:gradient_submit:failure_rate_5m"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.95
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Services Healthy",
      "description": "Cluster health context for the launch stack.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "mohawk:services_up:count"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Node Agents Healthy",
      "description": "Scrape target health for node-agent paths that consume the transport layer.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "mohawk:node_agents_up:count"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Transport Path Throughput Trend",
      "description": "Gradient submit throughput and proof verification traffic used as the MRC transport proxy.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "mohawk:gradient_submit:rate1m",
          "legendFormat": "gradient submit"
        },
        {
          "refId": "B",
          "expr": "mohawk:proof_verifications:rate1m",
          "legendFormat": "proof verifications"
        },
        {
          "refId": "C",
          "expr": "mohawk:accelerator_ops:rate1m",
          "legendFormat": "accelerator ops"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Round Latency Quantiles",
      "description": "FedAvg round latency p50/p95/p99 used to spot transport regressions.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "mohawk:fedavg_round_latency_quantile_ms{quantile=\"p50\"}",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "mohawk:fedavg_round_latency_quantile_ms{quantile=\"p95\"}",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "mohawk:fedavg_round_latency_quantile_ms{quantile=\"p99\"}",
          "legendFormat": "p99"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Gradient Norm Quantiles",
      "description": "Gradient quality and payload-shape proxy for the transport path.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "mohawk:fedavg_gradient_norm_quantile{quantile=\"p50\"}",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "mohawk:fedavg_gradient_norm_quantile{quantile=\"p95\"}",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "mohawk:fedavg_gradient_norm_quantile{quantile=\"p99\"}",
          "legendFormat": "p99"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Accelerator Op Latency p95",
      "description": "Compression and verification latency for transport-adjacent accelerator operations.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(mohawk_accelerator_op_latency_ms_bucket[5m])))",
          "legendFormat": "{{operation}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 22
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Byzantine Filtered (5m)",
      "description": "Gradients rejected by Byzantine filtering in the transport/aggregation path.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(mohawk_fedavg_byzantine_filtered_total[5m]))"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 22
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "sovereign-mohawk",
    "mohawk",
    "v2",
    "ops",
    "mrc",
    "transport"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "Sovereign Mohawk | MRC Transport",
  "version": 1
}
