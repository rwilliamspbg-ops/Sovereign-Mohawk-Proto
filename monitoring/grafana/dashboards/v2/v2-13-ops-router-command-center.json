{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Router Health Snapshot",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Router Throughput (req/s)",
      "description": "Total router request throughput over the last minute.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(mohawk_router_requests_total[1m]))"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Router Success Rate (5m)",
      "description": "Share of successful router requests in the past 5 minutes.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(mohawk_router_requests_total{result=\"success\"}[5m])) / clamp_min(sum(rate(mohawk_router_requests_total[5m])), 1e-9)"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.95
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Router Failure Rate (5m)",
      "description": "Share of failed router requests in the past 5 minutes.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(mohawk_router_requests_total{result=\"failure\"}[5m])) / clamp_min(sum(rate(mohawk_router_requests_total[5m])), 1e-9)"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.03
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Provenance Ledger Records",
      "description": "Current number of persisted cross-vertical provenance records.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "mohawk_router_provenance_records"
        }
      ],
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Traffic and Error Analytics",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Endpoint Throughput (req/s)",
      "description": "Per-endpoint router throughput over 5 minutes.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (endpoint) (rate(mohawk_router_requests_total[5m]))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Failures by Endpoint (req/s)",
      "description": "Failure request rate split by endpoint.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (endpoint) (rate(mohawk_router_requests_total{result=\"failure\"}[5m]))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Failure Ratio by Endpoint (5m)",
      "description": "Failure ratio per endpoint to isolate noisy routes quickly.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (endpoint) (rate(mohawk_router_requests_total{result=\"failure\"}[5m])) / clamp_min(sum by (endpoint) (rate(mohawk_router_requests_total[5m])), 1e-9)",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.03
              }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Provenance Ledger Growth (records/min)",
      "description": "Net new provenance records per minute. Flatline can indicate traffic interruption.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "deriv(mohawk_router_provenance_records[10m]) * 60"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 11,
      "type": "row",
      "title": "Operational Forensics",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      }
    },
    {
      "id": 12,
      "type": "table",
      "title": "Request Rate by Endpoint/Result/Reason (5m)",
      "description": "Live triage table for endpoint behavior including rejection reasons.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (endpoint, result, reason) (rate(mohawk_router_requests_total[5m]))",
          "format": "table",
          "instant": true
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 24
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Value",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Router Runtime Health",
      "description": "Router process health context from runtime metrics.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "go_goroutines",
          "legendFormat": "goroutines"
        },
        {
          "refId": "B",
          "expr": "process_resident_memory_bytes",
          "legendFormat": "resident_memory"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "resident_memory"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          }
        ]
      }
    }
  ],
