{
  "annotations": {"list": []},
  "editable": true,
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["mohawk", "v2", "engineering", "migration", "control-plane"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "title": "MOHAWK v2 - Engineering Migration Control Plane",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Migration Requests (ops/s)",
      "description": "Total migration endpoint request throughput.",
      "datasource": {"type": "prometheus", "uid": "grafana"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [{"expr": "mohawk:migration_requests:rate1m", "refId": "A"}]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Migration p95 Latency (ms)",
      "description": "p95 latency across migration API endpoints.",
      "datasource": {"type": "prometheus", "uid": "grafana"},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [{"expr": "mohawk:migration_latency_ms:p95", "refId": "A"}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Dual-Crypto Path Share",
      "description": "Share of migrate requests using dual cryptographic signatures.",
      "datasource": {"type": "prometheus", "uid": "grafana"},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "expr": "sum(rate(mohawk_migration_signature_path_total{path=\"dual_crypto\"}[5m])) / clamp_min(sum(rate(mohawk_migration_signature_path_total[5m])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Authz Denials (5m)",
      "description": "Authorization denials for migration/admin paths.",
      "datasource": {"type": "prometheus", "uid": "grafana"},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [{"expr": "mohawk:authz_denials:rate5m", "refId": "A"}]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Migration Requests by Endpoint",
      "description": "Endpoint-level throughput for status/config/digest/migrate handlers.",
      "datasource": {"type": "prometheus", "uid": "grafana"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 5},
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(mohawk_migration_requests_total[5m]))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Migration Success vs Failure",
      "description": "Result breakdown to validate reliability under load.",
      "datasource": {"type": "prometheus", "uid": "grafana"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 5},
      "targets": [
        {
          "expr": "sum(rate(mohawk_migration_requests_total{result=\"success\"}[5m]))",
          "legendFormat": "success",
          "refId": "A"
        },
        {
          "expr": "sum(rate(mohawk_migration_requests_total{result=\"failure\"}[5m]))",
          "legendFormat": "failure",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Migration Latency by Endpoint (p95)",
      "description": "Per-endpoint p95 latency from histogram buckets.",
      "datasource": {"type": "prometheus", "uid": "grafana"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 14},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(mohawk_migration_request_latency_ms_bucket[5m])))",
          "legendFormat": "{{endpoint}} p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Signature Path Reliability",
      "description": "Reliability by legacy_controls vs dual_crypto path.",
      "datasource": {"type": "prometheus", "uid": "grafana"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 14},
      "targets": [
        {
          "expr": "sum by (path, result) (rate(mohawk_migration_signature_path_total[5m]))",
          "legendFormat": "{{path}} {{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Authorization Denials by Endpoint",
      "description": "Security pressure and potential misuse hotspots.",
      "datasource": {"type": "prometheus", "uid": "grafana"},
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 23},
      "targets": [
        {
          "expr": "sum by (endpoint, reason) (rate(mohawk_authz_denials_total[5m]))",
          "legendFormat": "{{endpoint}} {{reason}}",
          "refId": "A"
        }
      ]
    }
  ]
}
