  "title": "Sovereign Mohawk | Security & PQC Compliance",
  "version": 4,
  "panels": [
    {
      "id": 9,
      "type": "row",
      "title": "Compliance Posture Snapshot",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {}
      },
      "options": {}
    },
    {
      "id": 1,
      "type": "stat",
      "title": "PQC Enforcement Composite",
      "description": "Minimum enforcement state across critical PQC controls (1=fully enforced).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "mohawk:pqc_policy_enforced:min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Authz Denials Rate (5m)",
      "description": "Authorization denial pressure on protected endpoints.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "mohawk:authz_denials:rate5m",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          }
        }
      }
    },
