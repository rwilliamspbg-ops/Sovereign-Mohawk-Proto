    {
      "id": 5,
      "type": "timeseries",
      "title": "PQC Policy States",
      "description": "Per-policy enforcement state (1=enabled, 0=disabled).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-main"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "targets": [
        {
          "expr": "mohawk_pqc_policy_enabled",
          "legendFormat": "{{policy}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "min",
            "max"
          ],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "thresholdsStyle": {
              "mode": "line"
            }
          }
        }
      }
    },
    {
